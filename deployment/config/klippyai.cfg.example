# KlippyAI runtime configuration
#
# Copy or adapt this file into printer_data/config/klippyai/klippyai.cfg on a host install.
# It is designed to be editable from Mainsail.
#
# Notes:
# - Restart klippyai-agent after editing this file.
# - Hidden install metadata is stored in `/etc/klippyai/klippyai.env`.
# - Keep API keys in /etc/klippyai/klippyai.env, not in this file.

[install]
printer_data_root: /home/pi/printer_data  # Printer data root. Example: /home/pi/printer_data
mainsail_config_dir: /home/pi/printer_data/config  # Config dir that contains the managed klippyai/ folder. Example: /home/pi/printer_data/config

[printer_identity]
firmware_flavor:  # Main firmware flavor. Examples: Kalico, Klipper
firmware_version:  # Firmware version string. Examples: v2026.05.00-4, v0.13.0-221
host_model:  # Host computer / SBC model. Examples: BigTreeTech CB1, Raspberry Pi 4 Model B
host_distribution:  # Linux distribution on the host. Examples: Debian GNU/Linux 11 (bullseye) 11, Armbian 24.2 Bookworm
mainboard:  # Printer controller board model. Examples: BTT Manta E3EZ, BTT Octopus Pro
toolhead:  # Toolhead board / electronics model. Examples: BTT EBB36, FYSETC H36 Combo, Orbiter Nitehawk

[printer_capabilities]
probe_type: none  # Probe family. Examples: none, bltouch, beacon, eddy
accelerometer: none  # Accelerometer family. Examples: none, adxl345, lis2dw
filament_sensor: none  # Filament sensor family. Examples: none, switch, motion
bed_mesh_configured: false  # Whether bed mesh is configured. Examples: true, false
input_shaper_configured: false  # Whether input shaper is configured. Examples: true, false
canbus_enabled: false  # Whether the printer uses CAN anywhere. Examples: true, false
addons:  # Comma-separated addons. Examples: OctoEverywhere, KAMP, KlipperScreen

[config_context]
root_config_file:  # Root Klipper config entry point. Examples: printer.cfg, machines/voron/printer-main.cfg
ignore_globs:  # Comma-separated exclude globs. Examples: backups/**, archive/**, timelapse/**

[server]
port: 8811  # Local agent port. Examples: 8811, 9911
root_path: /klippyai  # Public reverse-proxy path. Examples: /klippyai, /ai
data_dir: /var/lib/klippyai  # Local runtime data directory. Examples: /var/lib/klippyai, /srv/klippyai/data
checkpoint_db: /var/lib/klippyai/checkpoints.sqlite  # SQLite checkpoint DB path. Examples: /var/lib/klippyai/checkpoints.sqlite, /srv/klippyai/checkpoints.sqlite
enable_write_actions: false  # Reserved for future write actions. Keep this false.

[llm]
llm_provider: stub  # Chat backend provider. Examples: stub, openai
openai_model: gpt-5.4-mini  # OpenAI model when provider = openai. Examples: gpt-5.4-mini, gpt-5.5

[logs]
collect_host_logs: true  # Whether to collect host logs. Examples: true, false
logs_dir_path: /home/pi/printer_data/logs  # Directory that contains Klipper, Moonraker, and KlippyAI logs. Examples: /home/pi/printer_data/logs, /srv/printer_data/logs
agent_log_file_name: klippyai.log  # KlippyAI runtime log filename. Examples: klippyai.log, ai-agent.log
agent_log_level: INFO  # Runtime log verbosity. Examples: INFO, DEBUG, WARNING
log_tail_lines_default: 100  # Default tail length when no override exists. Examples: 100, 200
excluded_logs:  # Comma-separated denylist by name, stem, or glob. Examples: klippyai.log, crowsnest, *_debug.log

[log_tail_lines]
klippy: 100  # Tail lines for klippy.log
moonraker: 200  # Tail lines for moonraker.log
klippyai: 100  # Tail lines for klippyai.log

[system]
collect_systemd_diagnostics: true  # Whether to collect systemctl and journal diagnostics. Examples: true, false
journal_lines: 200  # Journal lines to include per service. Examples: 100, 200, 400
